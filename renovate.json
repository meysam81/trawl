{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreModulesAndTests",
    "group:monorepos",
    "group:recommended",
    "replacements:all",
    "workarounds:all"
  ],
  "packageRules": [
    {
      "automerge": true,
      "automergeStrategy": "rebase",
      "matchUpdateTypes": ["patch", "pin", "lockFileMaintenance", "digest"]
    }
  ]
}
